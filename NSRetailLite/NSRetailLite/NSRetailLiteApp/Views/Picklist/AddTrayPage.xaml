<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NSRetailLiteApp.Views.Picklist.AddTrayPage"
           xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" 
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui">
    <Grid Padding="20" ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, Auto, Auto, Auto" BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" 
          ColumnSpacing="10" RowSpacing="10">
        <Label Text="{Binding Path=PickListItemModel.ItemName}" FontSize="Subtitle" LineBreakMode="WordWrap" HorizontalOptions="Center" HorizontalTextAlignment="Center" 
               Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"/>
        <Label Text="{Binding Path=PickListItemModel.ItemCode}" FontSize="Subtitle" LineBreakMode="WordWrap" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"/>
        <Label Text="{Binding Path=PickListItemModel.MRP, StringFormat='MRP : {0}'}" Grid.Column="2" Grid.Row="1"/>
        <Label Text="Tray #" VerticalOptions="Center" Grid.Row="2" Grid.Column="0"/>
        <Entry Text="{Binding Path=TrayNumber}" Placeholder="Enter or scan tray #" Loaded="TrayNumber_Loaded" x:Name="txtTrayNumber" 
               Grid.Row="2" Grid.Column="1"  Grid.ColumnSpan="2">
            <Entry.Behaviors>
                <toolkit:SelectAllTextBehavior />
            </Entry.Behaviors>
        </Entry>
        <Label Text="Tray Quantity" VerticalOptions="Center" Grid.Row="3" Grid.Column="0"/>
        <Entry Text="{Binding Path=PickedQuantity}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1"  Grid.ColumnSpan="2">
            <Entry.Behaviors>
                <toolkit:SelectAllTextBehavior />
            </Entry.Behaviors>
        </Entry>
        <Button Text="Save" Command="{Binding Path=SaveCommand}" HorizontalOptions="Center" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"/>
    </Grid>
</mct:Popup>