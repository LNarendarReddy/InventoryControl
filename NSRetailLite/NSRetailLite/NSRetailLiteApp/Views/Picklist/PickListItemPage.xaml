<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="NSRetailLiteApp.Views.Picklist.PickListItemPage"
            xmlns:models="clr-namespace:NSRetailLiteApp.Models"
            xmlns:views="clr-namespace:NSRetailLiteApp.Views.Picklist"
            Title="{Binding Path=Title}">
    <ContentPage Title="Available items">
        <Grid>
            <VerticalStackLayout>
                <Button Text="Submit" Margin="10" HorizontalOptions="Center"/>
                <CollectionView ItemsSource="{Binding Path=PickListItemsModel}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PickListItemModel">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItem IconImageSource="stockcountingadd.png" 
                                               Command="{Binding Path=BindingContext.AddTrayCommand
                                                    , Source={RelativeSource AncestorType={x:Type views:PickListItemPage}}}" 
                                                    CommandParameter="{Binding .}" 
                                           BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                </SwipeView.RightItems>
                                <Frame  BorderColor="Transparent" Padding="0">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer NumberOfTapsRequired="2" CommandParameter="{Binding .}"
                                            Command="{Binding Path=BindingContext.AddTrayQuantityCommand, Source={RelativeSource AncestorType={x:Type views:PickListItemPage}}}" />
                                    </Frame.GestureRecognizers>
                                    <Grid Padding="5" RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="*, Auto, *" RowSpacing="5" ColumnSpacing="10">                                        
                                        <Label Text="{Binding Path=ItemName}" Grid.Row="0" Grid.Column="0" LineBreakMode="WordWrap" FontSize="Subtitle" Grid.ColumnSpan="3" />
                                        <Label Text="{Binding Path=ItemCode}" Grid.Row="1" Grid.Column="0" FontSize="Small" />
                                        <Label Text="{Binding Path=MRP, StringFormat='MRP:{0}'}" Grid.Row="1" Grid.Column="2" FontSize="Small" />
                                        <Label Text="{Binding Path=Quantity, StringFormat='Quantity: {0}'}" Grid.Column="0" Grid.Row="2"/>
                                        <Label Text="{Binding Path=AvailableQuantity, StringFormat='Available Qty: {0}'}" Grid.Row="2" Grid.Column="2"/>
                                        <Rectangle HeightRequest="2" BackgroundColor="PaleVioletRed" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" />
                                    </Grid>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>                
            </VerticalStackLayout>
            <ActivityIndicator IsRunning="{Binding Path=IsLoading}" WidthRequest="150"/>
        </Grid>
    </ContentPage>
    <ContentPage Title="Tray-wise item data" Appearing="ContentPage_Loaded">
        <Grid>
            <Grid Margin="10" RowSpacing="10" RowDefinitions="Auto, *">
                <Frame Padding="5" Grid.Row="0" HorizontalOptions="Center">
                    <HorizontalStackLayout>
                        <Label Text="Select tray #:" VerticalTextAlignment="Center"/>
                        <Picker Title="Select tray # to scroll"
                    ItemsSource="{Binding Path=TrayWiseData}"
                    SelectedIndexChanged="Picker_SelectedIndexChanged"
                    ItemDisplayBinding="{Binding Path=Name}"
                    x:Name="cmbTrayWisePicker"
                    HorizontalTextAlignment="Center"
                    VerticalOptions="End"/>
                    </HorizontalStackLayout>
                </Frame>

                <CollectionView ItemsSource="{Binding Path=TrayWiseData}" IsGrouped="True" x:Name="cvTrayWiseData" Grid.Row="1">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto" Padding="20, 0, 20, 0" ColumnSpacing="5"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                <Label Text="{Binding Name, StringFormat='Tray #: {0}'}" FontSize="Large" FontAttributes="Bold" Grid.Column="0" TextColor="White"/>
                                <Label Text="Items:" FontSize="Large" TextColor="White" Grid.Column="2" />
                                <Label Text="{Binding Count}" FontSize="Large" FontAttributes="Bold" TextColor="White" Grid.Column="3" />
                                <Label Text="Pieces:" FontSize="Large" TextColor="White" Grid.Column="4" />
                                <Label Text="{Binding PieceCount}" FontSize="Large" FontAttributes="Bold" TextColor="White" Grid.Column="5" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PickListItemModel">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItem IconImageSource="stockcountingdiscard.png" CommandParameter="{Binding .}"
                                        Command="{Binding Path=BindingContext.DeleteItemDetailCommand
                                        , Source={RelativeSource AncestorType={x:Type views:PickListItemPage}}}" 
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                </SwipeView.RightItems>
                                <Frame  BorderColor="Transparent" Padding="0">
                                    <Grid Padding="5" RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="Auto, *, Auto, Auto" RowSpacing="5" ColumnSpacing="10">
                                        
                                        <Label FontSize="Subtitle" LineBreakMode="WordWrap" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding Path=ItemName}" />
                                        <Label Text="{Binding Path=ItemCode}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" />
                                        <Label Text="{Binding Path=MRP, StringFormat='MRP: {0}'}" Grid.Row="1" Grid.Column="2" HorizontalTextAlignment="End" />
                                        <Label Text="{Binding Path=Quantity, StringFormat='Quantity: {0}'}" Grid.Row="1" Grid.Column="3" />
                                        <Rectangle HeightRequest="2" BackgroundColor="PaleVioletRed" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" />
                                    </Grid>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
            <ActivityIndicator IsRunning="{Binding Path=IsLoading}" WidthRequest="150"/>
        </Grid>
    </ContentPage>
</TabbedPage>